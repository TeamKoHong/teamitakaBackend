# 🌐 서버 설정
PORT=3001

# 🗄️ 데이터베이스 설정
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=teamitaka_database
DATABASE_URL=mysql://user:password@localhost:3306/teamitaka_database

DB_DIALECT=mysql
DB_CHARSET=utf8mb4
NODE_ENV=development

# 🌐 CORS
# 프로덕션 웹 도메인은 CORS_ORIGINS에 명시하고, Capacitor 네이티브 앱은
# 기본적으로 https://localhost Origin을 추가 허용합니다.
CORS_ORIGINS=https://www.teamitaka.com
CORS_NATIVE_ORIGINS=https://localhost

# 🔐 인증 및 시크릿
UNIVCERT_API_KEY=your_univcert_api_key
JWT_SECRET=your_jwt_secret_key
APP_JWT_EXPIRES_IN=1d

# 🔐 관리자 계정
ADMIN_EMAIL=admin@teamitaka.com
ADMIN_PASSWORD=your_admin_password
ADMIN_PASSWORD_HASH=your_admin_password_hash

# 📧 이메일 서비스 설정
EMAIL_SERVICE=sendgrid
EMAIL_FROM=noreply@teamitaka.com
SENDGRID_API_KEY=your_sendgrid_api_key

# 📱 Google OAuth (소셜 로그인)
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id

# ⏰ 스케줄 작업 설정 (Cron Jobs)
CRON_ENABLED=true
CRON_SCHEDULE=0 0 * * *
TIMEZONE=Asia/Seoul

# 📱 APNs Push Notifications (iOS)
# Apple Developer Portal에서 Keys > Create a Key > Enable "Apple Push Notifications service (APNs)"
APNS_KEY_ID=YOUR_KEY_ID
APNS_TEAM_ID=NWS3TZY4B9
APNS_BUNDLE_ID=com.teamitaka.teamitaka
APNS_KEY_PATH=/etc/secrets/AuthKey.p8
